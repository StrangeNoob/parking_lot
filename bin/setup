#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

echo "==> Installing dependencies..."
npm install

echo ""
echo "==> Building TypeScript..."
npm run build

echo ""
echo "==> Running unit tests..."
npm test

echo ""
echo "==> Running functional tests..."
bin/run_functional_tests

echo ""
echo "==> Setup complete."
